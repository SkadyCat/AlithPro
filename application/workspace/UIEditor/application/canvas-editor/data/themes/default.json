{
  "version": "1.0",
  "name": "暗黑奇幻",
  "description": "PoE / Diablo 风格暗色主题，纯 CSS 渐变纹理，不污染 session JSON",
  "types": {
    "CanvasPanel": {
      "overlay": "linear-gradient(160deg, rgba(40,28,15,0.35) 0%, rgba(8,5,2,0.55) 100%)",
      "innerShadow": "inset 0 0 24px rgba(0,0,0,0.65), inset 0 1px 0 rgba(180,130,60,0.06)"
    },
    "Border": {
      "overlay": "linear-gradient(to bottom, rgba(180,130,60,0.14) 0%, rgba(30,18,8,0.38) 55%, rgba(0,0,0,0.32) 100%)",
      "innerShadow": "inset 0 1px 0 rgba(220,170,80,0.18), inset 0 -1px 0 rgba(0,0,0,0.55), inset 1px 0 0 rgba(200,150,60,0.07), inset -1px 0 0 rgba(0,0,0,0.35)"
    },
    "TextBlock": {
      "overlay": "",
      "innerShadow": ""
    },
    "RichTextBlock": {
      "overlay": "",
      "innerShadow": "inset 0 1px 2px rgba(0,0,0,0.4)"
    },
    "Button": {
      "overlay": "linear-gradient(to bottom, rgba(180,120,40,0.28) 0%, rgba(100,55,12,0.42) 60%, rgba(30,15,5,0.52) 100%)",
      "innerShadow": "inset 0 1px 0 rgba(255,210,90,0.22), inset 0 -2px 5px rgba(0,0,0,0.52), inset 1px 0 0 rgba(200,150,50,0.1), inset -1px 0 0 rgba(0,0,0,0.3)"
    },
    "Image": {
      "overlay": "repeating-linear-gradient(45deg, rgba(80,60,30,0.13) 0px, rgba(80,60,30,0.13) 10px, transparent 10px, transparent 20px), repeating-linear-gradient(-45deg, rgba(80,60,30,0.13) 0px, rgba(80,60,30,0.13) 10px, transparent 10px, transparent 20px)",
      "innerShadow": "inset 0 0 12px rgba(0,0,0,0.65)"
    },
    "TileView": {
      "pattern": "repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(120,85,30,0.13) 60px), repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(120,85,30,0.13) 60px)",
      "overlay": "linear-gradient(135deg, rgba(15,10,5,0.6) 0%, rgba(5,3,1,0.75) 100%)",
      "innerShadow": "inset 0 0 32px rgba(0,0,0,0.72), inset 0 2px 0 rgba(180,130,50,0.08)"
    },
    "ListView": {
      "pattern": "repeating-linear-gradient(0deg, transparent, transparent 29px, rgba(100,70,25,0.1) 30px)",
      "overlay": "linear-gradient(180deg, rgba(10,7,3,0.5) 0%, rgba(5,3,1,0.65) 100%)",
      "innerShadow": "inset 0 0 20px rgba(0,0,0,0.6)"
    },
    "TreeView": {
      "overlay": "linear-gradient(180deg, rgba(12,8,4,0.45) 0%, rgba(5,3,1,0.6) 100%)",
      "innerShadow": "inset 0 0 16px rgba(0,0,0,0.55)"
    },
    "ProgressBar": {
      "overlay": "linear-gradient(to right, rgba(0,180,80,0.18) 0%, rgba(0,230,110,0.09) 70%, rgba(0,100,40,0.05) 100%)",
      "innerShadow": "inset 0 1px 3px rgba(0,0,0,0.65), inset 0 -1px 0 rgba(0,200,85,0.2)"
    },
    "Slider": {
      "overlay": "linear-gradient(to bottom, rgba(0,0,0,0.42) 0%, rgba(100,70,30,0.2) 50%, rgba(0,0,0,0.42) 100%)",
      "innerShadow": "inset 0 2px 5px rgba(0,0,0,0.72)"
    },
    "EditableText": {
      "overlay": "linear-gradient(to bottom, rgba(0,0,0,0.32) 0%, rgba(20,14,6,0.22) 100%)",
      "innerShadow": "inset 0 1px 4px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(150,100,40,0.18)"
    },
    "EditableTextBox": {
      "overlay": "linear-gradient(to bottom, rgba(0,0,0,0.32) 0%, rgba(20,14,6,0.22) 100%)",
      "innerShadow": "inset 0 1px 4px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(150,100,40,0.18)"
    },
    "MultiLineEditableText": {
      "overlay": "linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(15,10,4,0.2) 100%)",
      "innerShadow": "inset 0 1px 4px rgba(0,0,0,0.58), inset 0 0 0 1px rgba(140,95,35,0.15)"
    },
    "CheckBox": {
      "overlay": "",
      "innerShadow": "inset 0 1px 2px rgba(0,0,0,0.5)"
    },
    "ComboBoxString": {
      "overlay": "linear-gradient(to bottom, rgba(60,40,15,0.25) 0%, rgba(20,12,4,0.4) 100%)",
      "innerShadow": "inset 0 1px 0 rgba(200,150,60,0.12), inset 0 -1px 0 rgba(0,0,0,0.5)"
    },
    "SpinBox": {
      "overlay": "linear-gradient(to right, rgba(0,0,0,0.3) 0%, rgba(40,28,10,0.2) 100%)",
      "innerShadow": "inset 0 1px 3px rgba(0,0,0,0.55)"
    },
    "ScrollBox": {
      "overlay": "linear-gradient(135deg, rgba(18,12,5,0.4) 0%, rgba(5,3,1,0.55) 100%)",
      "innerShadow": "inset 0 0 18px rgba(0,0,0,0.6)"
    },
    "HorizontalBox": {
      "overlay": "linear-gradient(to right, rgba(35,22,8,0.3) 0%, rgba(10,6,2,0.45) 100%)",
      "innerShadow": "inset 0 0 12px rgba(0,0,0,0.45)"
    },
    "VerticalBox": {
      "overlay": "linear-gradient(to bottom, rgba(35,22,8,0.3) 0%, rgba(10,6,2,0.45) 100%)",
      "innerShadow": "inset 0 0 12px rgba(0,0,0,0.45)"
    },
    "Overlay": {
      "overlay": "radial-gradient(ellipse at center, rgba(80,50,15,0.2) 0%, rgba(0,0,0,0.5) 100%)",
      "innerShadow": "inset 0 0 20px rgba(0,0,0,0.6)"
    },
    "GridPanel": {
      "pattern": "repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(100,70,25,0.1) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(100,70,25,0.1) 40px)",
      "overlay": "linear-gradient(135deg, rgba(12,8,3,0.4) 0%, rgba(5,3,1,0.55) 100%)",
      "innerShadow": "inset 0 0 16px rgba(0,0,0,0.55)"
    },
    "Throbber": {
      "overlay": "radial-gradient(ellipse at center, rgba(0,150,255,0.12) 0%, transparent 70%)",
      "innerShadow": ""
    },
    "BackgroundBlur": {
      "overlay": "linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%)",
      "innerShadow": "inset 0 0 8px rgba(255,255,255,0.05)"
    }
  }
}
